# Copy to .env and fill in. .env is gitignored. Variable names are case-sensitive
# and match what the code reads (lowercase for the API keys — intentional).

# OpenRouter — covers BOTH te3 embeddings (retrieval/backends.OpenRouterEmbedBackend)
# and gen/sel chat (chat_backend.OpenRouterChat). One key does it all.
openrouter_api_key=

# Optional: native DeepSeek (chat_backend.DeepSeekNativeChat) — only if you prefer
# DeepSeek's own API over routing DeepSeek through OpenRouter. Otherwise leave blank.
deepseek_api_key=

# HuggingFace — needed only to pull the GATED EmbeddingGemma base for the local
# (stock / fine-tuned) embedder. Not needed for te3 or scoring.
HF_TOKEN=
